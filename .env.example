# Web3Forms endpoint + access key. Same values across all ctrl-alt-elite
# free-site deployments. The automation framework sets these automatically
# on the Vercel project at provisioning time; for local dev copy this file
# to .env.local and fill in your own test key from https://web3forms.com.
NEXT_PUBLIC_CONTACT_ENDPOINT=https://api.web3forms.com/submit
NEXT_PUBLIC_CONTACT_ACCESS_KEY=
